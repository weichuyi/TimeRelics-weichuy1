<?xml version='1.0' encoding='utf-8'?>
<widget id="com.weichuyi.hu" version="1.6.6" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <feature name="StatusBar">
        <param name="android-package" value="org.apache.cordova.statusbar.StatusBar" />
        <param name="onload" value="true" />
    </feature>
    <feature name="File">
        <param name="android-package" value="org.apache.cordova.file.FileUtils" />
        <param name="onload" value="true" />
    </feature>
    <allow-navigation href="cdvfile:*" />
    <feature name="FileTransfer">
        <param name="android-package" value="org.apache.cordova.filetransfer.FileTransfer" />
    </feature>
    <feature name="Zip">
        <param name="android-package" value="org.apache.cordova.Zip" />
    </feature>
    <name>时光拾遗</name>
    <description>
        我们这一路走来真的很容易
    </description>
    <author email="weichu@yi.com" href="https://shi-guang-shi-yi.com">
        weichuyi
    </author>
    <content src="index.html" />
    <access origin="*" />
    <access origin="https://raw.githubusercontent.com" />
    <access origin="https://github.com" />
    <access origin="https://objects.githubusercontent.com" />
    <access origin="https://github-releases.githubusercontent.com" />
    <allow-navigation href="https://*/*" />
    <allow-navigation href="http://*/*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <icon src="res/icon/icon.png" />
    <preference name="loglevel" value="DEBUG" />
    <preference name="StatusBarOverlaysWebView" value="true" />
    <preference name="AndroidWindowSplashScreenAnimatedIcon" value="res/icon/icon.png" />
    <preference name="AndroidWindowSplashScreenBackground" value="#fff9f5" />
    <preference name="MediaPlaybackRequiresUserAction" value="false" />
    <preference name="AllowInlineMediaPlayback" value="true" />
    <preference name="BackgroundColor" value="0xfffff9f5" />
    <preference name="StatusBarBackgroundColor" value="#fff9f5" />
    <preference name="StatusBarStyle" value="darkcontent" />
</widget>
